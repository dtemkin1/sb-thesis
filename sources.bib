@article{bertsimasBusRoutingOptimization2020,
  title = {Bus {{Routing Optimization Helps Boston Public Schools Design Better Policies}}},
  author = {Bertsimas, Dimitris and Delarue, Arthur and Eger, William and Hanlon, John and Martin, Sebastien},
  date = {2020-01},
  journaltitle = {INFORMS Journal on Applied Analytics},
  volume = {50},
