mcdp {
  provides used_C [Nat]
  provides used_B [Nat]
  provides used_BWC [Nat]
  provides used_WC [Nat]

  requires driver_cost [USD]

  constant yearly_pay_per_bus = 46571 USD

  required driver_cost >= (
    provided used_C +
    provided used_B +
    provided used_BWC +
    provided used_WC
  ) * yearly_pay_per_bus
}
